{
  "name": "openclaude",
  "version": "0.1.0",
  "description": "Mac desktop GUI client for Claude Code agent engine via OpenRouter",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "patch:sdk": "node scripts/patch-open-agent-sdk.mjs",
    "smoke:resume": "npm run patch:sdk && node scripts/resume-smoke-test.mjs",
    "dev": "npm run patch:sdk && vite",
    "build": "npm run patch:sdk && tsc && vite build",
    "preview": "vite preview",
    "typecheck": "npm run patch:sdk && tsc --noEmit",
    "package": "npm run build && electron-builder",
    "package:mac": "npm run build && electron-builder --mac"
  },
  "dependencies": {
    "@shipany/open-agent-sdk": "^0.1.7",
    "highlight.js": "^11.11.1",
    "lucide-react": "^0.511.0",
    "marked": "^17.0.5",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.5.2",
    "autoprefixer": "^10.4.21",
    "electron": "^35.2.1",
    "electron-builder": "^26.0.12",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
