    "figures": "^6.0.0",
    "fuse.js": "^7.0.0",
    "get-east-asian-width": "^1.3.0",
    "google-auth-library": "^9.14.0",
    "highlight.js": "^11.10.0",
    "https-proxy-agent": "^7.0.0",
    "ignore": "^7.0.0",
    "indent-string": "^5.0.0",
    "ink": "^5.1.0",
    "jsonc-parser": "^3.3.0",
    "lodash-es": "^4.17.21",
    "lru-cache": "^11.0.0",
    "marked": "^15.0.0",
