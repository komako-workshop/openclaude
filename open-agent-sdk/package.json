    "picomatch": "^4.0.0",
    "proper-lockfile": "^4.1.2",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-reconciler": "^0.32.0",
    "semver": "^7.6.0",
    "shell-quote": "^1.8.0",
    "signal-exit": "^4.1.0",
    "stack-utils": "^2.0.0",
    "strip-ansi": "^7.1.0",
    "supports-hyperlinks": "^3.1.0",
    "tree-kill": "^1.2.2",
    "type-fest": "^4.30.0",
    "undici": "^7.0.0",
