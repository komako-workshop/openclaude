    "zod-to-json-schema": "^3.24.0"
  },
  "optionalDependencies": {
    "image-processor-napi": "*",
    "sharp": ">=0.33.0",
    "turndown": ">=7.0.0"
  },
  "devDependencies": {
    "@types/diff": "^7.0.0",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.0.0",
    "@types/proper-lockfile": "^4.1.4",
    "@types/react": "^19.2.14",
    "@types/semver": "^7.5.0",
    "@types/shell-quote": "^1.7.5",
    "@types/ws": "^8.5.0",
    "esbuild": "^0.27.4",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "license": "MIT",
  "keywords": [
    "open-agent-sdk",
    "shipany",
    "agent",
    "sdk",
    "claude",
    "anthropic",
    "ai",
    "llm",
    "tools",
    "agentic",
    "coding-agent"
  ]
}
